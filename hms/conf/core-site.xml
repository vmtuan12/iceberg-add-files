<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <!-- S3A filesystem implementation -->
  <property>
    <name>fs.s3a.impl</name>
    <value>org.apache.hadoop.fs.s3a.S3AFileSystem</value>
  </property>

  <!-- MinIO endpoint -->
  <property>
    <name>fs.s3a.endpoint</name>
    <value>http://minio:9000</value>
  </property>

  <!-- Service account credentials -->
  <property>
    <name>fs.s3a.access.key</name>
    <value>root</value>
  </property>
  <property>
    <name>fs.s3a.secret.key</name>
    <value>root123456</value>
  </property>

  <!-- Path-style access required for MinIO -->
  <property>
    <name>fs.s3a.path.style.access</name>
    <value>true</value>
  </property>

  <!-- Disable SSL for local MinIO -->
  <property>
    <name>fs.s3a.connection.ssl.enabled</name>
    <value>false</value>
  </property>

  <!-- Use AWS SDK v1 signing -->
  <property>
    <name>fs.s3a.aws.credentials.provider</name>
    <value>org.apache.hadoop.fs.s3a.SimpleAWSCredentialsProvider</value>
  </property>

  <!-- Faster directory operations on object stores -->
  <property>
    <name>fs.s3a.directory.marker.retention</name>
    <value>keep</value>
  </property>
</configuration>
